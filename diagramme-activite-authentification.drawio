        <!-- dec_user → erreur (Non) -->
        <mxCell id="e9" value="Non" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="dec_user" target="act_err_user" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- erreur user → retour formulaire -->
        <mxCell id="e10" value="Corriger" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="act_err_user" target="act_form" parent="1">
