<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-05-20T00:00:00.000Z" agent="Claude" version="21.0.0">
  <diagram name="Authentification Admin - Connexion" id="activity-auth-admin">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="1">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITRE -->
        <mxCell id="title" value="Diagramme d'Activité — Connexion Admin / Autorité&#xa;Alert Civique — Spring Boot 3 · JWT · BCrypt · React Web (Admin Panel)" style="text;html=1;strokeColor=#23445D;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontStyle=1;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="580" height="60" as="geometry" />
        </mxCell>

        <!-- NOTE CONTEXTUELLE -->
        <mxCell id="note_ctx" value="&lt;b&gt;Contexte :&lt;/b&gt; Alert Civique est une application de signalement d'incidents civils.&#xa;Les citoyens font leurs signalements &lt;b&gt;sans compte ni connexion&lt;/b&gt; (mode anonyme).&#xa;Seuls les &lt;b&gt;administrateurs et les autorités&lt;/b&gt; ont un compte et doivent s'authentifier." style="text;html=1;strokeColor=#d79b00;fillColor=#ffe6cc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="270" y="95" width="640" height="65" as="geometry" />
        </mxCell>

        <!-- NOEUD INITIAL -->
        <mxCell id="start" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="555" y="190" width="40" height="40" as="geometry" />
        </mxCell>

        <!-- Ouverture interface admin -->
        <mxCell id="act_open" value="Admin / Autorité ouvre l'interface web&#xa;alert_civique_admin (React — port 3001)&#xa;LoginPage.tsx" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="395" y="260" width="360" height="65" as="geometry" />
        </mxCell>

        <!-- Formulaire connexion -->
        <mxCell id="act_form" value="Saisir identifiants&#xa;email, mot de passe" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="395" y="365" width="360" height="55" as="geometry" />
        </mxCell>

        <!-- Décision : formulaire valide ? -->
        <mxCell id="dec_form" value="Formulaire&#xa;valide ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="475" y="455" width="200" height="75" as="geometry" />
        </mxCell>

        <!-- Erreur formulaire vide -->
        <mxCell id="act_err_form" value="Afficher message d'erreur&#xa;(champs obligatoires)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="750" y="463" width="180" height="58" as="geometry" />
        </mxCell>

        <!-- POST /api/auth/login -->
        <mxCell id="act_post_login" value="POST /api/auth/login&#xa;AuthController.login(LoginDTO)&#xa;{ email, password }" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="395" y="570" width="360" height="65" as="geometry" />
        </mxCell>

        <!-- Spring Security -->
        <mxCell id="act_springsec" value="Spring Security intercepte la requête&#xa;UserDetailsService.loadUserByUsername(email)&#xa;Recherche User en BDD (MariaDB)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="395" y="675" width="360" height="65" as="geometry" />
        </mxCell>

        <!-- Décision : utilisateur trouvé ? -->
        <mxCell id="dec_user" value="Utilisateur&#xa;trouvé ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="475" y="778" width="200" height="75" as="geometry" />
        </mxCell>

        <!-- Erreur user non trouvé -->
        <mxCell id="act_err_user" value="401 Unauthorized&#xa;'Email inconnu'" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="750" y="786" width="180" height="58" as="geometry" />
        </mxCell>

        <!-- Vérification mot de passe BCrypt -->
        <mxCell id="act_bcrypt" value="Vérification mot de passe&#xa;BCryptPasswordEncoder.matches()&#xa;hash BDD vs mot de passe soumis" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="395" y="895" width="360" height="65" as="geometry" />
        </mxCell>

        <!-- Décision : mot de passe OK ? -->
        <mxCell id="dec_pass" value="Mot de passe&#xa;correct ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="475" y="998" width="200" height="75" as="geometry" />
        </mxCell>

        <!-- Erreur mot de passe -->
        <mxCell id="act_err_pass" value="401 Unauthorized&#xa;'Mot de passe incorrect'" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="750" y="1006" width="180" height="58" as="geometry" />
        </mxCell>

        <!-- Génération JWT -->
        <mxCell id="act_gen_jwt" value="Générer token JWT&#xa;JwtService.generateToken(userDetails)&#xa;Payload : { sub: email, userId, role, iat, exp }" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="395" y="1120" width="360" height="65" as="geometry" />
        </mxCell>

        <!-- Retour HTTP 200 -->
        <mxCell id="act_return" value="HTTP 200 OK — Retourner AuthResponseDTO&#xa;{ token, userId, email, role }" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="395" y="1225" width="360" height="55" as="geometry" />
        </mxCell>

        <!-- Stockage token côté client -->
        <mxCell id="act_store" value="Stocker token JWT&#xa;localStorage.setItem('token', jwt)&#xa;Mettre à jour AuthContext { userId, role, isAuthenticated: true }" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="395" y="1320" width="360" height="70" as="geometry" />
        </mxCell>

        <!-- Redirection Dashboard Admin -->
        <mxCell id="act_dashboard" value="Redirection vers Dashboard Admin&#xa;DashBoard.tsx — Gestion des signalements&#xa;Accès complet : reports, livestreams, utilisateurs" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="395" y="1435" width="360" height="70" as="geometry" />
        </mxCell>

        <!-- NOEUD FINAL -->
        <mxCell id="end" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#000000;strokeColor=#000000;double=1;" vertex="1" parent="1">
          <mxGeometry x="555" y="1550" width="40" height="40" as="geometry" />
        </mxCell>

        <!-- ============================= -->
        <!-- EDGES                         -->
        <!-- ============================= -->

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="act_open" parent="1">
          <mxGeometry relative="1" as="geometry" />
