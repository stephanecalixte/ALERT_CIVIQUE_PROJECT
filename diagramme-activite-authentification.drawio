        <!-- dec_form → erreur (Non) -->
        <mxCell id="e4" value="Non" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="dec_form" target="act_err_form" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- erreur → retour formulaire -->
        <mxCell id="e5" value="Corriger" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="act_err_form" target="act_form" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="960" y="392" />
              <mxPoint x="755" y="392" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- dec_form → POST login (Oui) -->
        <mxCell id="e6" value="Oui" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="dec_form" target="act_post_login" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="act_post_login" target="act_springsec" parent="1">
          <mxGeometry relative="1" as="geometry" />
