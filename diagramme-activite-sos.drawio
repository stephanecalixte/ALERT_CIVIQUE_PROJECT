        <mxCell id="dec_gps" value="GPS&#xa;disponible ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="480" y="617" width="200" height="70" as="geometry" /></mxCell>
        <mxCell id="act_nogps" value="locationText = 'Position inconnue'&#xa;lat / lon = undefined" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1"><mxGeometry x="750" y="625" width="190" height="54" as="geometry" /></mxCell>

        <!-- ÉTAPE 4 -->
        <mxCell id="act_geocode" value="Reverse géocodage&#xa;reverseGeocodeAsync() → adresse lisible (rue, ville)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="390" y="730" width="380" height="55" as="geometry" /></mxCell>

        <!-- ÉTAPE 5 -->
