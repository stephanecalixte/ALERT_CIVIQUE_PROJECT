        <mxCell id="act_offline" value="⚠ Sauvegarde hors ligne&#xa;AsyncStorage (@report_offline_queue)&#xa;retryOfflineQueue() à la reconnexion" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1"><mxGeometry x="750" y="1028" width="190" height="70" as="geometry" /></mxCell>

