      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <mxCell id="title" value="Diagramme d'Activité — Déclenchement SOS&#xa;Alert Civique · React Native · Spring Boot · MariaDB" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontStyle=1;fontSize=14;" vertex="1" parent="1"><mxGeometry x="300" y="10" width="580" height="55" as="geometry" /></mxCell>

        <mxCell id="note" value="Contexte : Le citoyen signale un incident urgent via le bouton SOS.&#xa;Aucune connexion requise — le signalement peut être anonyme." style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;whiteSpace=wrap;rounded=1;fontSize=11;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="300" y="73" width="580" height="45" as="geometry" /></mxCell>

        <!-- NOEUD INITIAL -->
        <mxCell id="start" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1"><mxGeometry x="560" y="145" width="40" height="40" as="geometry" /></mxCell>

        <!-- ÉTAPE 1 -->
        <mxCell id="act_sos" value="&lt;b&gt;Utilisateur appuie sur le bouton SOS&lt;/b&gt;&#xa;SosButton.tsx → handleSosPress()&#xa;useReportFlow.triggerSos()" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="390" y="220" width="380" height="65" as="geometry" /></mxCell>

        <!-- ÉTAPE 2 -->
        <mxCell id="act_perm" value="Demande permission localisation&#xa;expo-location: requestForegroundPermissions()" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="390" y="323" width="380" height="55" as="geometry" /></mxCell>

        <!-- DÉCISION permission -->
        <mxCell id="dec_perm" value="Permission&#xa;accordée ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="480" y="415" width="200" height="70" as="geometry" /></mxCell>
        <mxCell id="err_perm" value="Afficher message d'erreur&#xa;permission refusée" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1"><mxGeometry x="750" y="423" width="190" height="54" as="geometry" /></mxCell>

        <!-- ÉTAPE 3 -->
