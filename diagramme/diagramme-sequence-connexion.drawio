        <!-- MESSAGES -->
        <mxCell id="m1" value="1. Saisit email + mot de passe" style="endArrow=block;endFill=1;html=1;fontSize=10;fontStyle=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="100" y="175" as="sourcePoint" /><mxPoint x="300" y="175" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m2" value="2. POST /api/auth/login  { email, password }" style="endArrow=block;endFill=1;html=1;fontSize=10;fontStyle=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="230" as="sourcePoint" /><mxPoint x="560" y="230" as="targetPoint" /></mxGeometry></mxCell>

        <mxCell id="m3" value="3. UserDetailsService.loadUserByUsername(email)" style="endArrow=block;endFill=1;html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="560" y="285" as="sourcePoint" /><mxPoint x="560" y="320" as="targetPoint" /><Array as="points"><mxPoint x="645" y="285" /><mxPoint x="645" y="320" /></Array></mxGeometry></mxCell>

