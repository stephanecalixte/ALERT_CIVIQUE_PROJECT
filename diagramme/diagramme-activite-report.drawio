        <mxCell id="act_rejected" value="REJECTED ❌&#xa;Signalement invalidé" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1"><mxGeometry x="750" y="1461" width="175" height="54" as="geometry" /></mxCell>
