        <!-- ÉTAPE 7 Admin reçoit -->
        <mxCell id="act_recv" value="Admin consulte la liste des signalements&#xa;GET /api/report — ReportsList.tsx&#xa;Signalement visible : status PENDING 🔴" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1"><mxGeometry x="390" y="1058" width="380" height="65" as="geometry" /></mxCell>

