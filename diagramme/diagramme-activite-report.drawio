        <mxCell id="act_review" value="Admin examine le signalement&#xa;Vérification : description, localisation, type d'alerte,&#xa;médias, priorité (DecisionLevel)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1"><mxGeometry x="390" y="1163" width="380" height="70" as="geometry" /></mxCell>

        <!-- ÉTAPE 9 Mise à jour statut -->
        <mxCell id="act_update" value="PUT /api/report/{id}&#xa;Mise à jour du statut — updateReport(id, status, token)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1"><mxGeometry x="390" y="1273" width="380" height="55" as="geometry" /></mxCell>

