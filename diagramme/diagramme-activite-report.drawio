      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <mxCell id="title" value="Diagramme d'Activité — Signalement (Report)&#xa;Alert Civique · React Native · Spring Boot · MariaDB · Admin React" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontStyle=1;fontSize=14;" vertex="1" parent="1"><mxGeometry x="300" y="10" width="580" height="55" as="geometry" /></mxCell>

        <mxCell id="note" value="Contexte : Signalement d'incident par un citoyen — sans connexion requise (mode anonyme possible)." style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;whiteSpace=wrap;rounded=1;fontSize=11;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="300" y="73" width="580" height="35" as="geometry" /></mxCell>

        <!-- NOEUD INITIAL -->
        <mxCell id="start" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1"><mxGeometry x="560" y="135" width="40" height="40" as="geometry" /></mxCell>

        <!-- ÉTAPE 1 -->
        <mxCell id="act_open" value="Citoyen ouvre ReportScreen&#xa;Formulaire de signalement (React Native)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="390" y="205" width="380" height="55" as="geometry" /></mxCell>

        <!-- ÉTAPE 2 -->
        <mxCell id="act_form" value="Saisit description, catégorie, type d'alerte&#xa;(photo optionnelle — anonymous ou userId)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="390" y="298" width="380" height="55" as="geometry" /></mxCell>

        <!-- DÉCISION formulaire -->
        <mxCell id="dec_form" value="Formulaire&#xa;valide ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="480" y="390" width="200" height="70" as="geometry" /></mxCell>
        <mxCell id="err_form" value="Afficher erreur&#xa;(champs manquants)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1"><mxGeometry x="750" y="398" width="190" height="54" as="geometry" /></mxCell>

        <!-- ÉTAPE 3 Géolocalisation -->
        <mxCell id="act_geo" value="POST /api/geolocalisation&#xa;GeolocalisationService.create()  —  { lat, lon, timestamp }" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="390" y="500" width="380" height="55" as="geometry" /></mxCell>

        <!-- ÉTAPE 4 Report -->
        <mxCell id="act_rep" value="POST /api/report&#xa;ReportService.createReport()&#xa;{ description, status:PENDING, geolocalisationId, anonymous, userId? }" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="390" y="595" width="380" height="70" as="geometry" /></mxCell>

        <!-- DÉCISION réseau -->
        <mxCell id="dec_net" value="Réseau&#xa;disponible ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="480" y="703" width="200" height="70" as="geometry" /></mxCell>
        <mxCell id="act_offline" value="⚠ saveOffline()&#xa;AsyncStorage&#xa;retryOfflineQueue() à la reconnexion" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1"><mxGeometry x="750" y="703" width="190" height="70" as="geometry" /></mxCell>

        <!-- ÉTAPE 5 Backend -->
        <mxCell id="act_backend" value="Backend : Validation DTO  —  ReportMapperService.toEntity()&#xa;reportRepository.save(report)  —  reportId généré (MariaDB)&#xa;Status = PENDING" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="390" y="823" width="380" height="70" as="geometry" /></mxCell>

        <!-- ÉTAPE 6 Confirmation -->
        <mxCell id="act_confirm" value="Signalement envoyé ✓&#xa;Afficher ConfirmationScreen — state = 'done'" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="390" y="933" width="380" height="55" as="geometry" /></mxCell>

