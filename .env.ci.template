# Alert Civique - CI/CD Environment Configuration Template
# SECURITY WARNING: This file contains sensitive configuration
# Do NOT commit actual secrets to version control
# 
# For CI/CD environments, copy this to .env.ci and fill in your actual values
# Make sure .env.ci is in .gitignore

# ===============================
# PostgreSQL / SonarQube Database
# ===============================
# Default values are "sonar" for testing
# For production, use strong credentials
POSTGRES_USER=sonar
POSTGRES_PASSWORD=sonar

# ===============================
# SonarQube Configuration
# ===============================
SONAR_JDBC_USERNAME=sonar
SONAR_JDBC_PASSWORD=sonar

# ===============================
# Jenkins Configuration (Optional)
# ===============================
# JENKINS_HOME and credentials can be managed via Jenkins UI
# For advanced setup, configure credentials in Jenkins directly
# JENKINS_ADMIN_USER=admin
# JENKINS_ADMIN_PASSWORD=change_me

# ===============================
# Application Secrets (Optional for CI/CD)
# ===============================
# If running integration tests in CI/CD, these may be needed:
# JWS_SECRET=your-test-secret-key
# JWT_SECRET=your-test-secret-key
# JWT_ACTIVATION_SECRET=your-base64-encoded-test-secret
